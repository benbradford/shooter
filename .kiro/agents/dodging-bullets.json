{
  "name": "dodging-bullets",
  "description": "Specialized agent for Dodging Bullets game - 2D top-down shooter with Phaser and TypeScript ECS architecture",
  "model": "claude-sonnet-4.5-1m",
  "tools": ["@builtin"],
  "allowedTools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "use_subagent",
    "knowledge",
    "ls"
  ],
  "resources": [
    "file://README.md",
    "file://docs/**/*.md",
    "file://src/ecs/index.ts"
  ],
  "prompt": "file://dodging-bullets.md",
  "toolsSettings": {
    "subagent": {
      "trustedAgents": ["db-implementor", "db-design"]
    }
  }
}
